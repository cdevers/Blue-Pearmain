def cmd_checkpoint(args):
    """Run a WAL checkpoint and report results."""
    import yaml
    from db.db import Database

    with open(args.config) as f:
        config = yaml.safe_load(f)
    db = Database(Path(config["database"]["path"]).expanduser())
    result = db.checkpoint(mode=args.mode.upper())
    db.close()

    busy        = result["busy"]
    log         = result["log"]
    checkpointed = result["checkpointed"]

    if log == 0:
        print("WAL is empty — nothing to checkpoint.")
    elif busy > 0:
        print(
            f"Checkpoint incomplete: {checkpointed}/{log} frames moved "
            f"({busy} frame(s) blocked by active readers). "
            f"Run again when the UI and other readers are stopped for a full truncate."
        )
    else:
        print(f"Checkpoint complete: {checkpointed}/{log} frames moved, WAL truncated.")


def _inject_argv(args, pairs):
    """Rebuild sys.argv from parsed args so subcommand main()s parse correctly."""
    new_argv = [sys.argv[0]]
    for flag, value in pairs:
        if value is None or value is False:
            continue
        if value is True:
            new_argv.append(flag)
        else:
            new_argv.extend([flag, value])
    sys.argv = new_argv


def _step_args(base, **overrides):
    """Return a copy of base Namespace with overrides applied."""
    import argparse as _ap
    d = vars(base).copy()
    d.update(overrides)
    return _ap.Namespace(**d)


def cmd_all(args):
    """
    Run the full periodic maintenance sequence:
      1. scan --all       full Apple Photos index refresh
      2. poll             catch recent Flickr uploads
      3. thumbs           populate missing thumbnail paths
      4. pipeline         metadata sync + auto-apply non-conflict proposals
      5. reconcile --fix  repair DB/Flickr mismatches
      6. sync-albums      push album memberships to Flickr
      7. checkpoint       trim the WAL file
    Each step runs independently; a failure is logged and the sequence continues.
    Not included: 'scan --all' can be skipped with --skip-scan; 'bp poll --backfill'
    and 'bp scan' incremental are intentionally excluded (manual operations).
    """
    import logging
    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(asctime)s  %(levelname)-8s  %(name)s  %(message)s",
        datefmt="%Y-%m-%dT%H:%M:%S",
    )
    log = logging.getLogger("blue-pearmain.all")

    steps = [
        ("scan --all",      cmd_scan,        _step_args(args, all=True,       dry_run=False, days=None)),
        ("poll",            cmd_poll,        _step_args(args, backfill=False, dry_run=False, days=None)),
        ("thumbs",          cmd_thumbs,      args),
        ("pipeline",        cmd_pipeline,    _step_args(args, limit=None)),
        ("reconcile --fix", cmd_reconcile,   _step_args(args, fix=True,       apply_proposals=False, limit=None)),
        ("sync-albums",     cmd_sync_albums, _step_args(args, dry_run=False,  album=None,    limit=None)),
        ("checkpoint",      cmd_checkpoint,  _step_args(args, mode="truncate")),
    ]

    errors = []
    for name, fn, step_args in steps:
        log.info("all: -> %s", name)
        try:
            fn(step_args)
        except SystemExit as e:
            code = e.code if e.code is not None else 0
            if code != 0:
                log.warning("all: %s failed (exit %s) -- continuing", name, code)
                errors.append(name)
        except Exception as exc:
            log.warning("all: %s failed: %s -- continuing", name, exc)
            errors.append(name)

    if errors:
        log.warning("all: completed with %d error(s): %s", len(errors), ", ".join(errors))
    else:
        log.info("all: all steps complete")


def main():
    parser = argparse.ArgumentParser(
        prog="bp",
        description="Blue Pearmain — Flickr + Apple Photos review tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--config",  default="config/config.yml", help="Path to config.yml")
    parser.add_argument("--verbose", action="store_true")

    sub = parser.add_subparsers(dest="command", metavar="<command>")
    sub.required = True

    # stats
    p_stats = sub.add_parser("stats", help="Show photo counts by privacy state")
    p_stats.add_argument("--oneliner", action="store_true", help="Single-line summary for watch/loop use")

    # poll
    p_poll = sub.add_parser("poll", help="Poll Flickr for new/updated photos")
    p_poll.add_argument("--backfill", action="store_true", help="Poll full history, not just recent")
    p_poll.add_argument("--days",     type=int, default=None, help="Days to look back (with --backfill)")
    p_poll.add_argument("--dry-run",  action="store_true")

    # scan
    p_scan = sub.add_parser("scan", help="Scan Apple Photos library")
    p_scan.add_argument("--all",     action="store_true", help="Scan entire library")
    p_scan.add_argument("--days",    type=int, default=None)
    p_scan.add_argument("--dry-run", action="store_true")

    # thumbs
    sub.add_parser("thumbs", help="Populate missing thumbnail paths")

    # pipeline
    p_pipe = sub.add_parser("pipeline", help="Sync-metadata then auto-apply non-conflict proposals")
    p_pipe.add_argument("--limit", type=int, default=None,
                        help="Cap number of proposals applied (default: unlimited)")

    # reconcile
    p_rec = sub.add_parser("reconcile", help="Check DB state vs actual Flickr state")
    p_rec.add_argument("--fix",              action="store_true", help="Re-push mismatches")
    p_rec.add_argument("--apply-proposals",  action="store_true", help="Apply pending non-conflict metadata proposals")
    p_rec.add_argument("--limit",            type=int, default=None)

    # ui
    p_ui = sub.add_parser("ui", help="Start the review UI")
    p_ui.add_argument("--port",  type=int, default=5173)
    p_ui.add_argument("--debug", action="store_true")

    # sync-albums
    p_sync = sub.add_parser("sync-albums", help="Sync Apple Photos albums → Flickr photosets")
    p_sync.add_argument("--dry-run", action="store_true")
    p_sync.add_argument("--album",   default=None, help="Sync only this album name")
    p_sync.add_argument("--limit",   type=int, default=None)
    p_sync.add_argument("--verbose", action="store_true")

    # sync-metadata
    p_meta = sub.add_parser("sync-metadata", help="Pull Flickr metadata → Apple Photos")
    p_meta.add_argument("--dry-run",        action="store_true",
                        help="Compare and log; do not write to Photos or DB")
    p_meta.add_argument("--limit",          type=int, default=None)
    p_meta.add_argument("--photo-id",       type=int, default=None,
                        help="Process only this DB photo_id")
    p_meta.add_argument("--conflicts-only", action="store_true",
                        help="Detect and record conflicts only; skip Photos writes")
    p_meta.add_argument("--force",          action="store_true",
                        help="Process all photos, ignoring meta_last_harmonized_at")
    p_meta.add_argument("--verbose",        action="store_true")

    # link-orphans
    p_link = sub.add_parser(
        "link-orphans",
        help="Merge split Photos-only / Flickr-only records that share a capture timestamp",
    )
    p_link.add_argument("--dry-run", action="store_true",
                        help="Find pairs but do not write to DB")
    p_link.add_argument("--limit",   type=int, default=None,
                        help="Max pairs to process (default: all)")

    # all
    sub.add_parser(
        "all",
        help="Full maintenance run: scan --all, poll, thumbs, pipeline, reconcile --fix, sync-albums, checkpoint",
    )

    # checkpoint
    p_ckpt = sub.add_parser("checkpoint", help="Run a WAL checkpoint to shrink the WAL file")
    p_ckpt.add_argument(
        "--mode", default="truncate",
        choices=["truncate", "passive", "full", "restart"],
        help="Checkpoint mode (default: truncate)",
    )

    args = parser.parse_args()

    # Attach config/verbose to all subcommands
    if not hasattr(args, "oneliner"):        args.oneliner = False
    if not hasattr(args, "dry_run"):         args.dry_run = False
    if not hasattr(args, "all"):             args.all = False
    if not hasattr(args, "days"):            args.days = None
    if not hasattr(args, "backfill"):        args.backfill = False
    if not hasattr(args, "fix"):             args.fix = False
    if not hasattr(args, "apply_proposals"): args.apply_proposals = False
    if not hasattr(args, "limit"):           args.limit = None
    if not hasattr(args, "port"):            args.port = 5173
    if not hasattr(args, "debug"):           args.debug = False
    if not hasattr(args, "album"):           args.album = None
    if not hasattr(args, "photo_id"):        args.photo_id = None
    if not hasattr(args, "conflicts_only"):  args.conflicts_only = False
    if not hasattr(args, "mode"):            args.mode = "truncate"

    dispatch = {
        "pipeline":      cmd_pipeline,
        "stats":         cmd_stats,
        "poll":          cmd_poll,
        "scan":          cmd_scan,
        "thumbs":        cmd_thumbs,
        "reconcile":     cmd_reconcile,
        "ui":            cmd_ui,
        "sync-albums":   cmd_sync_albums,
        "sync-metadata": cmd_sync_metadata,
        "link-orphans":  cmd_link_orphans,
        "checkpoint":    cmd_checkpoint,
        "all":           cmd_all,
    }
    dispatch[args.command](args)


if __name__ == "__main__":
    main()
