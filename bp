def cmd_pipeline(args):
    """
    Run the full metadata sync pipeline without manual steps:
      1. bp sync-metadata  — diff cached values, generate proposals
      2. bp reconcile --apply-proposals  — auto-apply all non-conflict proposals
    Collision proposals are left pending for manual review in the UI.
    """
    import logging
    import yaml
    from pathlib import Path as _Path

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(asctime)s  %(levelname)-8s  %(name)s  %(message)s",
        datefmt="%Y-%m-%dT%H:%M:%S",
    )
    log = logging.getLogger("blue-pearmain.pipeline")

    with open(args.config) as f:
        config = yaml.safe_load(f)

    db_path      = config["database"]["path"]
    library_path = str(_Path(config.get("photos_library", {}).get("path", "")).expanduser())

    from db.db import Database
    db = Database(db_path)

    # Step 1: generate proposals for any photos whose cache has drifted
    from flickr.sync_metadata import _select_drift_filtered
    from flickr.metadata_puller import run_sync_engine

    photo_ids = _select_drift_filtered(db, limit=0)
    if photo_ids:
        log.info("pipeline: sync-metadata — %d photos to harmonise", len(photo_ids))
        sync_totals = run_sync_engine(db, photo_ids, verbose=args.verbose)
        log.info(
            "pipeline: sync-metadata done — proposals=%d  hash_matches=%d  skipped=%d  failed=%d",
            sync_totals["proposals"], sync_totals["hash_matches"],
            sync_totals["skipped"],   sync_totals["failed"],
        )
    else:
        log.info("pipeline: sync-metadata — nothing to harmonise (all in sync)")
        sync_totals = {}

    # Step 2: auto-apply non-conflict proposals (both tags and title/description)
    from flickr.proposal_applier import apply_batch

    apply_totals = apply_batch(
        db, library_path,
        conflict_types=["non_conflict"],
        limit=args.limit or 0,
    )
    log.info(
        "pipeline: apply done — applied=%d  failed=%d  superseded=%d",
        apply_totals["applied"], apply_totals["failed"], apply_totals["superseded"],
    )

    db.close()


