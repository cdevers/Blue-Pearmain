def _inject_argv(args, pairs):
    """Rebuild sys.argv from parsed args so subcommand main()s parse correctly."""
    new_argv = [sys.argv[0]]
    for flag, value in pairs:
        if value is None or value is False:
            continue
        if value is True:
            new_argv.append(flag)
        else:
            new_argv.extend([flag, str(value)])
    sys.argv = new_argv


def _step_args(base, **overrides):
    """Return a copy of base Namespace with overrides applied."""
    import argparse as _ap
    d = vars(base).copy()
    d.update(overrides)
    return _ap.Namespace(**d)


def cmd_status(args):
    """Print operational status: daemon state, queue sizes, pending proposals."""
    import yaml

    from db.db import Database
    from poller.status import collect_status, format_status, status_exit_code

    config_path = Path(args.config)
    if not config_path.exists():
        print(f"Error: config file not found: {config_path}", file=sys.stderr)
        sys.exit(2)

    try:
        with open(config_path) as f:
            config = yaml.safe_load(f)
    except Exception as e:
        print(f"Error reading config: {e}", file=sys.stderr)
        sys.exit(2)

    try:
        db = Database(Path(config["database"]["path"]).expanduser())
    except Exception as e:
        print(f"Error opening database: {e}", file=sys.stderr)
        sys.exit(2)

    try:
        status = collect_status(config, db)
    finally:
        db.close()

    print(format_status(status))
    sys.exit(status_exit_code(status))


