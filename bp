def _inject_argv(args, pairs):
    """Rebuild sys.argv from parsed args so subcommand main()s parse correctly."""
    new_argv = [sys.argv[0]]
    for flag, value in pairs:
        if value is None or value is False:
            continue
        if value is True:
            new_argv.append(flag)
        else:
            new_argv.extend([flag, str(value)])
    sys.argv = new_argv


def _step_args(base, **overrides):
    """Return a copy of base Namespace with overrides applied."""
    import argparse as _ap
    d = vars(base).copy()
    d.update(overrides)
    return _ap.Namespace(**d)


def cmd_doctor(args):
    """
    Validate config, environment, and DB state before running the pipeline.
    Prints a pass/fail checklist and exits non-zero if any required check fails.
    """
    import re
    import sqlite3
    import yaml

    OK   = "✓"
    FAIL = "✗"
    WARN = "!"
    issues = []

    def check(symbol, label, detail=""):
        line = f"  {symbol}  {label}"
        if detail:
            line += f"\n       → {detail}"
        print(line)
        if symbol == FAIL:
            issues.append(label)

    print()
    print("Blue Pearmain — environment check")
    print("─" * 40)

    # ── 1. Config file ────────────────────────────────────────────────────────
    config_path = Path(args.config)
    if not config_path.exists():
        check(FAIL, f"Config file: {config_path}", "File not found — copy config/config.example.yml to config/config.yml and fill in your values")
        print()
        print("Cannot continue: config file is required for all other checks.")
        sys.exit(1)

    try:
        with open(config_path) as f:
            config = yaml.safe_load(f)
        check(OK, f"Config file: {config_path}")
    except Exception as e:
        check(FAIL, f"Config file: {config_path}", f"YAML parse error: {e}")
        sys.exit(1)

    # ── 2. Required config keys ───────────────────────────────────────────────
    def _cfg(*keys, label=None):
        val = config
        for k in keys:
            val = (val or {}).get(k)
        display = label or ".".join(keys)
        if not val:
            check(FAIL, f"Config key {display}", "Missing or empty — check config.yml")
        else:
            check(OK, f"Config key {display}")

    _cfg("database", "path")
    _cfg("photos_library", "path")
    _cfg("flickr", "api_key")
    _cfg("flickr", "api_secret")
    _cfg("flickr", "oauth_token")
    _cfg("flickr", "oauth_token_secret")
    _cfg("photos_library", "self_name", label="photos_library.self_name")

    if "photos_library" in config and not config["photos_library"].get("self_name"):
        check(WARN, "photos_library.self_name is empty — photos of named people will not be filtered as self")

    # ── 3. Photos library path ────────────────────────────────────────────────
    photos_path_raw = (config.get("photos_library") or {}).get("path", "")
    if photos_path_raw:
        photos_path = Path(photos_path_raw).expanduser()
        if photos_path.exists():
            check(OK, f"Photos library: {photos_path}")
        else:
            check(FAIL, f"Photos library: {photos_path}", "Path not found — check photos_library.path in config.yml")

    # ── 4. Database ───────────────────────────────────────────────────────────
    db_path_raw = (config.get("database") or {}).get("path", "")
    db_ok = False
    if db_path_raw:
        db_path = Path(db_path_raw).expanduser()
        if not db_path.exists():
            check(WARN, f"Database: {db_path}", "File not found — will be created on first run")
            db_ok = False
        else:
            try:
                conn = sqlite3.connect(str(db_path))
                conn.execute("SELECT 1")
                conn.close()
                check(OK, f"Database: {db_path}")
                db_ok = True
            except Exception as e:
                check(FAIL, f"Database: {db_path}", f"Cannot open: {e}")

    # ── 5. Migrations ─────────────────────────────────────────────────────────
    if db_ok:
        try:
            conn = sqlite3.connect(str(db_path))
            conn.row_factory = sqlite3.Row
            applied = {r["name"] for r in conn.execute("SELECT name FROM schema_migrations").fetchall()}

            # Discover expected migrations by scanning migration files for MIGRATION_NAME
            migrations_dir = ROOT / "db" / "migrations"
            name_re = re.compile(r'^MIGRATION_NAME\s*=\s*["\']([^"\']+)["\']', re.MULTILINE)
            expected = {}
            for mf in sorted(migrations_dir.glob("migrate_*.py")):
                text = mf.read_text()
                m = name_re.search(text)
                if m:
                    expected[m.group(1)] = mf.name

            missing = {name: fname for name, fname in expected.items() if name not in applied}
            if missing:
                for name, fname in sorted(missing.items()):
                    check(WARN, f"Migration not applied: {name}",
                          f"Run: python db/migrations/{fname} --config {args.config}")
            else:
                last = sorted(applied)[-1] if applied else "(none)"
                check(OK, f"Migrations: all applied (latest: {last})")
            conn.close()
        except Exception as e:
            check(WARN, "Migrations: could not check", str(e))

    # ── 6. photoscript importable ─────────────────────────────────────────────
    try:
        import photoscript  # noqa: F401
        check(OK, "photoscript: importable")
    except ImportError:
        check(FAIL, "photoscript: not found", "Run: uv add photoscript")

    # ── 7. Flickr credentials ping (opt-in) ───────────────────────────────────
    if args.check_flickr:
        try:
            from flickr.flickr_client import FlickrClient
            fc = config.get("flickr", {})
            client = FlickrClient(
                api_key=fc.get("api_key", ""),
                api_secret=fc.get("api_secret", ""),
                oauth_token=fc.get("oauth_token", ""),
                oauth_token_secret=fc.get("oauth_token_secret", ""),
            )
            result = client._call("flickr.test.login")
            username = result.get("user", {}).get("username", {}).get("_content", "?")
            check(OK, f"Flickr credentials: authenticated as {username}")
        except Exception as e:
            check(FAIL, "Flickr credentials: API call failed", str(e))

    # ── Summary ───────────────────────────────────────────────────────────────
    print()
    if issues:
        print(f"  {len(issues)} problem(s) found:")
        for i in issues:
            print(f"    {FAIL}  {i}")
        print()
        sys.exit(1)
    else:
        print("  All checks passed.")
        print()


def cmd_all(args):
    """
    Run the full periodic maintenance sequence:
      1. scan --all              full Apple Photos index refresh
      2. poll                    catch recent Flickr uploads
      3. thumbs                  populate missing thumbnail paths
      4. sync-names-from-flickr  propagate Flickr renames → Apple Photos
      5. pipeline                metadata sync + auto-apply non-conflict proposals
      6. reconcile --fix         repair DB/Flickr mismatches
      7. sync-albums             push album memberships to Flickr
      8. sync-album-collections  sync folder hierarchy → Flickr Collections
      9. checkpoint              trim the WAL file
    Each step runs independently; a failure is logged and the sequence continues.
    Not included: 'scan --all' can be skipped with --skip-scan; 'bp poll --backfill'
    and 'bp scan' incremental are intentionally excluded (manual operations).

    Reconcile runs in a background thread so sync-albums and sync-album-collections
    can proceed while reconcile works through the Flickr API. The background thread
    is joined before checkpoint to ensure all writes are complete before the WAL flush.
    """
    import logging
    import threading
    from poller.bp_logging import configure
    configure("all", args.verbose)
    log = logging.getLogger("blue-pearmain.all")

    dry_run = getattr(args, "dry_run", False)
    if dry_run:
        log.info("all: dry-run mode — no external writes will be made")

    steps = [
        ("scan --all",             cmd_scan,                    _step_args(args, all=True,       dry_run=dry_run, days=None)),
        ("poll",                   cmd_poll,                    _step_args(args, backfill=False, dry_run=dry_run, days=None)),
        ("sync-names-from-flickr", cmd_sync_names_from_flickr, _step_args(args, dry_run=dry_run)),
        ("pipeline",               cmd_pipeline,                _step_args(args, limit=None,     dry_run=dry_run)),
        ("reconcile",       cmd_reconcile,   _step_args(args, fix=not dry_run, apply_proposals=False, limit=None)),
        ("sync-albums",            cmd_sync_albums,            _step_args(args, dry_run=dry_run, album=None,    limit=None)),
        ("sync-album-collections", cmd_sync_album_collections, _step_args(args, dry_run=dry_run, remove=False,   force=False)),
    ]
    if not dry_run:
        steps.insert(2, ("thumbs",     cmd_thumbs,     args))
        steps.append(   ("checkpoint", cmd_checkpoint, _step_args(args, mode="truncate")))

    errors = []
    bg_reconcile: threading.Thread | None = None
    bg_errors: list[str] = []   # written by bg thread, read after join()

    for name, fn, step_args in steps:
        # Join before checkpoint so all DB writes land before WAL flush
        if name == "checkpoint" and bg_reconcile is not None:
            log.info("all: waiting for background reconcile to finish...")
            bg_reconcile.join()
            errors.extend(bg_errors)
            bg_reconcile = None

        log.info("all: -> %s", name)

        if name == "reconcile":
            def _run(f=fn, sa=step_args):
                try:
                    f(sa)
                except SystemExit as e:
                    code = e.code if e.code is not None else 0
                    if code != 0:
                        bg_errors.append("reconcile")
                except Exception as exc:
                    log.warning("all: reconcile (background) failed: %s", exc)
                    bg_errors.append("reconcile")
            bg_reconcile = threading.Thread(target=_run, daemon=True)
            bg_reconcile.start()
            log.info("all: reconcile running in background — continuing with sync-albums")
            continue

        try:
            fn(step_args)
        except SystemExit as e:
            code = e.code if e.code is not None else 0
            if code != 0:
                log.warning("all: %s failed (exit %s) -- continuing", name, code)
                errors.append(name)
        except Exception as exc:
            log.warning("all: %s failed: %s -- continuing", name, exc)
            errors.append(name)

    # Dry-run has no checkpoint step; still wait for background reconcile
    if bg_reconcile is not None and bg_reconcile.is_alive():
        log.info("all: waiting for background reconcile to finish...")
        bg_reconcile.join()
        errors.extend(bg_errors)

    if errors:
        log.warning("all: completed with %d error(s): %s", len(errors), ", ".join(errors))
    else:
        log.info("all: all steps complete")


def main():
    parser = argparse.ArgumentParser(
        prog="bp",
        description="Blue Pearmain — Flickr + Apple Photos review tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--config",  default="config/config.yml", help="Path to config.yml")
    parser.add_argument("--verbose", action="store_true")

    sub = parser.add_subparsers(dest="command", metavar="<command>")
    sub.required = True

    # stats
    p_stats = sub.add_parser("stats", help="Show photo counts by privacy state")
    p_stats.add_argument("--oneliner", action="store_true", help="Single-line summary for watch/loop use")

    # poll
    p_poll = sub.add_parser("poll", help="Poll Flickr for new/updated photos")
    p_poll.add_argument("--backfill", action="store_true", help="Poll full history, not just recent")
    p_poll.add_argument("--days",     type=int, default=None, help="Days to look back (with --backfill)")
    p_poll.add_argument("--dry-run",  action="store_true")

    # scan
    p_scan = sub.add_parser("scan", help="Scan Apple Photos library")
    p_scan.add_argument("--all",     action="store_true", help="Scan entire library")
    p_scan.add_argument("--days",    type=int, default=None)
    p_scan.add_argument("--dry-run", action="store_true")

    # thumbs
    p_thumbs = sub.add_parser("thumbs", help="Populate missing thumbnail paths")
    p_thumbs.add_argument("--icloud",       action="store_true",
                          help="Trigger sequential AppleScript export for iCloud-only photos")
    p_thumbs.add_argument("--icloud-limit", type=int, default=50,
                          help="Max iCloud exports per run (default: 50)")

    # pipeline
    p_pipe = sub.add_parser("pipeline", help="Sync-metadata then auto-apply non-conflict proposals")
    p_pipe.add_argument("--dry-run", action="store_true",
                        help="Classify drift and count proposals; do not write or apply")
    p_pipe.add_argument("--limit", type=int, default=None,
                        help="Cap number of proposals applied (default: unlimited)")

    # reconcile
    p_rec = sub.add_parser("reconcile", help="Check DB state vs actual Flickr state")
    p_rec.add_argument("--fix",              action="store_true", help="Re-push mismatches")
    p_rec.add_argument("--apply-proposals",  action="store_true", help="Apply pending non-conflict metadata proposals")
    p_rec.add_argument("--limit",            type=int, default=None)

    # ui
    p_ui = sub.add_parser("ui", help="Start the review UI")
    p_ui.add_argument("--port",  type=int, default=5173)
    p_ui.add_argument("--host",  default=None,
                      help="Interface to bind (default: 127.0.0.1). Use 0.0.0.0 for LAN access.")
    p_ui.add_argument("--debug", action="store_true")

    # sync-albums
    p_sync = sub.add_parser("sync-albums", help="Sync Apple Photos albums → Flickr photosets")
    p_sync.add_argument("--dry-run", action="store_true")
    p_sync.add_argument("--album",   default=None, help="Sync only this album name")
    p_sync.add_argument("--limit",   type=int, default=None)
    p_sync.add_argument(
        "--coalesce",
        action="store_true",
        help="Detect and merge duplicate Flickr photosets (same title, overlapping dates)",
    )
    p_sync.add_argument("--verbose", action="store_true")

    # sync-album-collections
    p_col = sub.add_parser(
        "sync-album-collections",
        help="Sync Apple Photos folder hierarchy → Flickr Collections (Pro account required)",
    )
    p_col.add_argument("--dry-run", action="store_true",
                       help="Show what would be synced without making API calls")
    p_col.add_argument("--remove",  action="store_true",
                       help="Remove Flickr Collections for folders deleted from Photos")
    p_col.add_argument("--force",   action="store_true",
                       help="Skip confirmation prompts when used with --remove")
    p_col.add_argument("--verbose", action="store_true")

    # sync-names-from-flickr
    p_names = sub.add_parser(
        "sync-names-from-flickr",
        help="Sync Flickr photoset/Collection renames → Apple Photos albums/folders",
    )
    p_names.add_argument("--dry-run", action="store_true")
    p_names.add_argument("--verbose", action="store_true")

    # sync-metadata
    p_meta = sub.add_parser("sync-metadata", help="Pull Flickr metadata → Apple Photos")
    p_meta.add_argument("--dry-run",        action="store_true",
                        help="Compare and log; do not write to Photos or DB")
    p_meta.add_argument("--limit",          type=int, default=None)
    p_meta.add_argument("--photo-id",       type=int, default=None,
                        help="Process only this DB photo_id")
    p_meta.add_argument("--conflicts-only", action="store_true",
                        help="Detect and record conflicts only; skip Photos writes")
    p_meta.add_argument("--force",          action="store_true",
                        help="Process all photos, ignoring meta_last_harmonized_at")
    p_meta.add_argument("--verbose",        action="store_true")

    # link-orphans
    p_link = sub.add_parser(
        "link-orphans",
        help="Merge split Photos-only / Flickr-only records that share a capture timestamp",
    )
    p_link.add_argument("--dry-run", action="store_true",
                        help="Find pairs but do not write to DB")
    p_link.add_argument("--limit",   type=int, default=None,
                        help="Max pairs to process (default: all)")

    # all
    p_all = sub.add_parser(
        "all",
        help="Full maintenance run: scan --all, poll, thumbs, pipeline, reconcile --fix, sync-albums, sync-album-collections, checkpoint",
    )
    p_all.add_argument("--dry-run", action="store_true",
                       help="Run all stages read-only: no external writes. "
                            "Thumbs and checkpoint are skipped; reconcile runs without --fix.")

    # install-daemons
    p_install = sub.add_parser(
        "install-daemons",
        help="Install launchd agents to ~/Library/LaunchAgents",
    )
    p_install.add_argument("--dry-run", action="store_true",
                           help="Show what would be installed without writing files")

    # uninstall-daemons
    p_uninstall = sub.add_parser(
        "uninstall-daemons",
        help="Remove installed launchd agents from ~/Library/LaunchAgents",
    )
    p_uninstall.add_argument("--dry-run", action="store_true",
                             help="Show what would be removed without deleting files")

    # doctor
    p_doc = sub.add_parser("doctor", help="Preflight check: config, environment, and DB. Passing means startup is likely to succeed; it is not a guarantee of successful execution.")
    p_doc.add_argument("--check-flickr", action="store_true",
                       help="Make a live Flickr API call to verify credentials (requires network)")

    # checkpoint
    p_ckpt = sub.add_parser("checkpoint", help="Run a WAL checkpoint to shrink the WAL file")
    p_ckpt.add_argument(
        "--mode", default="truncate",
        choices=["truncate", "passive", "full", "restart"],
        help="Checkpoint mode (default: truncate)",
    )

    # deduplicator
    p_dedup = sub.add_parser(
        "deduplicator",
        help="Find and classify duplicate photos (dry-run by default)",
    )
    p_dedup.add_argument("--write", action="store_true", help="Write results to the DB")
    p_dedup.add_argument("--confirm", action="store_true", help="Delete Flickr discards (requires --write)")
    p_dedup.add_argument("--dry-run", action="store_true", help="Report without writing (default behaviour)")
    p_dedup.add_argument("--flickr", action="store_true", help="Detect Flickr re-upload duplicates")
    p_dedup.add_argument("--limit", type=int, default=None, metavar="N",
                         help="Maximum pairs to write (recommended for first live runs)")
    p_dedup.add_argument("--verbose", "-v", action="store_true", help="Show all uncertain pairs in report")

    # prune-proposals
    p_prune = sub.add_parser(
        "prune-proposals",
        help="Supersede spurious managed-tag proposals and delete old resolved proposals",
    )
    p_prune.add_argument(
        "--older-than", type=int, default=90, metavar="N",
        help="Delete resolved proposals older than N days (default: 90)",
    )
    p_prune.add_argument("--dry-run", action="store_true", help="Report counts without modifying the DB")

    args = parser.parse_args()

    # Attach config/verbose to all subcommands
    if not hasattr(args, "oneliner"):        args.oneliner = False
    if not hasattr(args, "dry_run"):         args.dry_run = False
    if not hasattr(args, "all"):             args.all = False
    if not hasattr(args, "days"):            args.days = None
    if not hasattr(args, "backfill"):        args.backfill = False
    if not hasattr(args, "fix"):             args.fix = False
    if not hasattr(args, "apply_proposals"): args.apply_proposals = False
    if not hasattr(args, "limit"):           args.limit = None
    if not hasattr(args, "port"):            args.port = 5173
    if not hasattr(args, "debug"):           args.debug = False
    if not hasattr(args, "album"):           args.album = None
    if not hasattr(args, "remove"):          args.remove = False
    if not hasattr(args, "force"):           args.force = False
    if not hasattr(args, "photo_id"):        args.photo_id = None
    if not hasattr(args, "conflicts_only"):  args.conflicts_only = False
    if not hasattr(args, "mode"):            args.mode = "truncate"
    if not hasattr(args, "check_flickr"):   args.check_flickr = False
    if not hasattr(args, "older_than"):     args.older_than = 90
    if not hasattr(args, "write"):          args.write = False
    if not hasattr(args, "confirm"):        args.confirm = False

    dispatch = {
        "pipeline":      cmd_pipeline,
        "stats":         cmd_stats,
        "poll":          cmd_poll,
        "scan":          cmd_scan,
        "thumbs":        cmd_thumbs,
        "reconcile":     cmd_reconcile,
        "ui":            cmd_ui,
        "sync-albums":             cmd_sync_albums,
        "sync-album-collections":  cmd_sync_album_collections,
        "sync-names-from-flickr":  cmd_sync_names_from_flickr,
        "sync-metadata":           cmd_sync_metadata,
        "link-orphans":  cmd_link_orphans,
        "checkpoint":       cmd_checkpoint,
        "all":              cmd_all,
        "install-daemons":   cmd_install_daemons,
        "uninstall-daemons": cmd_uninstall_daemons,
        "doctor":            cmd_doctor,
        "deduplicator":      cmd_deduplicator,
        "prune-proposals":   cmd_prune_proposals,
    }
    dispatch[args.command](args)


if __name__ == "__main__":
    main()
