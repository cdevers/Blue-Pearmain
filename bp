def cmd_install_daemons(args):
    """Install launchd plist files to ~/Library/LaunchAgents, substituting template tokens."""
    import shutil

    home = Path.home()
    uv = shutil.which("uv")
    if not uv:
        print("Error: 'uv' not found on PATH.", file=sys.stderr)
        sys.exit(1)

    plists = [
        "com.blue-pearmain.poller.plist",
        "com.blue-pearmain.pipeline.plist",
        "com.blue-pearmain.reviewer.plist",
        "com.blue-pearmain.reconcile.plist",
        "com.blue-pearmain.deduplicator.plist",
    ]
    launch_agents = home / "Library" / "LaunchAgents"
    if not args.dry_run:
        launch_agents.mkdir(parents=True, exist_ok=True)

    for plist_name in plists:
        src = ROOT / "config" / plist_name
        template = src.read_text()
        content = (template
                   .replace("__REPO__", str(ROOT))
                   .replace("__UV__", uv)
                   .replace("__HOME__", str(home)))
        dest = launch_agents / plist_name
        if args.dry_run:
            print(f"  would install: {dest}")
        else:
            dest.write_text(content)
            print(f"  installed: {dest}")

    if not args.dry_run:
        print()
        print("To load the daemons, run:")
        for plist_name in plists:
            print(f"  launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/{plist_name}")
        print()
        print("Or reload an already-loaded daemon:")
        print("  launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/<name>.plist")
        print("  launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/<name>.plist")


def cmd_uninstall_daemons(args):
    """Remove installed launchd plist files from ~/Library/LaunchAgents."""
    home = Path.home()
    plists = [
        "com.blue-pearmain.poller.plist",
        "com.blue-pearmain.pipeline.plist",
        "com.blue-pearmain.reviewer.plist",
        "com.blue-pearmain.reconcile.plist",
        "com.blue-pearmain.deduplicator.plist",
    ]
    launch_agents = home / "Library" / "LaunchAgents"
    any_found = False
    for plist_name in plists:
        dest = launch_agents / plist_name
        if dest.exists():
            any_found = True
            if args.dry_run:
                print(f"  would remove: {dest}")
            else:
                dest.unlink()
                print(f"  removed: {dest}")
        else:
            print(f"  not installed: {dest}")

    if any_found and not args.dry_run:
        print()
        print("If the daemons were loaded, unload them with:")
        for plist_name in plists:
            print(f"  launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/{plist_name}")
        print()
        print("(Ignore 'No such process' errors for daemons that were not running.)")


def cmd_checkpoint(args):
    """Run a WAL checkpoint and report results."""
    import yaml
    from db.db import Database

    with open(args.config) as f:
        config = yaml.safe_load(f)
    db = Database(Path(config["database"]["path"]).expanduser())
    result = db.checkpoint(mode=args.mode.upper())
    db.close()

    busy        = result["busy"]
    log         = result["log"]
    checkpointed = result["checkpointed"]

    if log == 0:
        print("WAL is empty — nothing to checkpoint.")
    elif busy > 0:
        print(
            f"Checkpoint incomplete: {checkpointed}/{log} frames moved "
            f"({busy} frame(s) blocked by active readers). "
            f"Run again when the UI and other readers are stopped for a full truncate."
        )
    else:
        print(f"Checkpoint complete: {checkpointed}/{log} frames moved, WAL truncated.")


