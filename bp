def cmd_all(args):
    """
    Run the full periodic maintenance sequence:
      1. scan --all              full Apple Photos index refresh
      2. poll                    catch recent Flickr uploads
      3. thumbs                  populate missing thumbnail paths
      4. sync-names-from-flickr  propagate Flickr renames → Apple Photos
      5. pipeline                metadata sync + auto-apply non-conflict proposals
      6. reconcile --fix         repair DB/Flickr mismatches
      7. sync-albums             push album memberships to Flickr
      8. sync-album-collections  sync folder hierarchy → Flickr Collections
      9. checkpoint              trim the WAL file
    Each step runs independently; a failure is logged and the sequence continues.
    Not included: 'scan --all' can be skipped with --skip-scan; 'bp poll --backfill'
    and 'bp scan' incremental are intentionally excluded (manual operations).
    """
    import logging
    from poller.bp_logging import configure
    configure("all", args.verbose)
    log = logging.getLogger("blue-pearmain.all")

    dry_run = getattr(args, "dry_run", False)
    if dry_run:
        log.info("all: dry-run mode — no external writes will be made")

    steps = [
        ("scan --all",             cmd_scan,                    _step_args(args, all=True,       dry_run=dry_run, days=None)),
        ("poll",                   cmd_poll,                    _step_args(args, backfill=False, dry_run=dry_run, days=None)),
        ("sync-names-from-flickr", cmd_sync_names_from_flickr, _step_args(args, dry_run=dry_run)),
        ("pipeline",               cmd_pipeline,                _step_args(args, limit=None,     dry_run=dry_run)),
        ("reconcile",              cmd_reconcile,               _step_args(args, fix=not dry_run, apply_proposals=False, limit=None)),
        ("sync-albums",            cmd_sync_albums,             _step_args(args, dry_run=dry_run, album=None,   limit=None)),
        ("sync-album-collections", cmd_sync_album_collections,  _step_args(args, dry_run=dry_run, remove=False, force=False)),
    ]
    if not dry_run:
        steps.insert(2, ("thumbs",     cmd_thumbs,     _step_args(args, icloud=False, icloud_limit=50)))
        steps.append(   ("checkpoint", cmd_checkpoint, _step_args(args, mode="truncate")))

    include_legacy = getattr(args, "include_legacy", False)
    if include_legacy:
        # _dry_run_skip_fn: returns a no-op that logs SKIPPED and returns
        # immediately, without calling the real step or touching config/NAS.
        def _dry_run_skip_fn(step_name: str):
            def _skipped(step_args):
                log.info(
                    "all: %s SKIPPED (no dry-run support) -- continuing",
                    step_name,
                )
            return _skipped

        # "pipeline" is always present in the base steps list — StopIteration here is a programmer mistake
        pipeline_idx = next(
            i for i, (n, _, _) in enumerate(steps) if n == "pipeline"
        )
        if dry_run:
            legacy_steps = [
                (
                    "index-legacy",
                    _dry_run_skip_fn("index-legacy"),
                    _step_args(args,
                               library=None, no_thumbnails=False, limit=None,
                               no_cache=False, refresh_cache=False),
                ),
                (
                    "match-legacy --apply",
                    _dry_run_skip_fn("match-legacy --apply"),
                    _step_args(args, apply=True, library_uuid=None, csv=None),
                ),
            ]
        else:
            legacy_steps = [
                (
                    "index-legacy",
                    cmd_index_legacy,
                    _step_args(args,
                               library=None, no_thumbnails=False, limit=None,
                               no_cache=False, refresh_cache=False),
                ),
                (
                    "match-legacy --apply",
                    cmd_match_legacy,
                    _step_args(args, apply=True, library_uuid=None, csv=None),
                ),
            ]
        for offset, step in enumerate(legacy_steps):
            steps.insert(pipeline_idx + 1 + offset, step)

    errors = []

    for name, fn, step_args in steps:
        if name == "match-legacy --apply" and "index-legacy" in errors:
            log.warning(
                "all: WARNING index-legacy failed — "
                "match-legacy --apply will use the last successfully indexed state"
            )
        log.info("all: -> %s", name)
        try:
            fn(step_args)
        except SystemExit as e:
            code = e.code if e.code is not None else 0
            if code != 0:
                log.warning("all: %s failed (exit %s) -- continuing", name, code)
                errors.append(name)
        except Exception as exc:
            log.warning("all: %s failed: %s -- continuing", name, exc)
            errors.append(name)

    if errors:
        log.warning("all: completed with %d error(s): %s", len(errors), ", ".join(errors))
    else:
        log.info("all: all steps complete")


