#!/usr/bin/env python3
"""
bp — Blue Pearmain command-line interface

Usage:
    bp pipeline [--dry-run] [--limit N]  Sync-metadata then auto-apply non-conflict proposals
    bp stats                        Show photo counts by privacy state
    bp poll [--backfill] [--days N] Poll Flickr for new/updated photos
    bp scan [--all] [--days N]      Scan Apple Photos library
    bp thumbs                       Populate missing thumbnail paths
    bp reconcile [--fix] [--limit N] Check DB state vs actual Flickr state
    bp link-orphans [--dry-run]     Merge split Photos/Flickr records
    bp checkpoint [--mode MODE]     Checkpoint the WAL file (default: truncate)
    bp sync-album-collections [--dry-run] [--remove [--force]]  Sync folder hierarchy → Flickr Collections
    bp sync-names-from-flickr [--dry-run]  Sync Flickr renames → Apple Photos
    bp all [--dry-run]              Full maintenance run (scan, poll, thumbs, sync-names-from-flickr, pipeline, reconcile, sync-albums, sync-album-collections, checkpoint)
    bp install-daemons [--dry-run]  Install launchd agents to ~/Library/LaunchAgents
    bp uninstall-daemons [--dry-run] Remove installed launchd agents
    bp ui                           Start the review UI (http://localhost:5173)
    bp doctor [--check-flickr]      Validate config, environment, and DB state

Global options:
    --config PATH   Path to config.yml (default: config/config.yml)
    --verbose       Extra logging

Run 'bp <subcommand> --help' for subcommand-specific options.
"""

import argparse
import sys
from pathlib import Path

# Ensure the repo root is on the path regardless of where bp is invoked from
ROOT = Path(__file__).parent.resolve()
sys.path.insert(0, str(ROOT))


def cmd_stats(args):
    import yaml
    from db.db import Database

    with open(args.config) as f:
        config = yaml.safe_load(f)
    db = Database(Path(config["database"]["path"]).expanduser())
    s = db.stats()

    by_state = s["by_state"]
    total    = s["total"]
    order = [
        ("candidate_public",  "Candidate public"),
        ("needs_review",      "Needs review"),
        ("approved_public",   "Approved public"),
        ("already_public",    "Already public"),
        ("keep_private",      "Keep private"),
        ("auto_private",      "Auto private"),
        ("skipped",           "Skipped"),
        ("duplicate_flickr",  "Duplicate Flickr"),
    ]

    flickr_linked = db.conn.execute(
        "SELECT COUNT(*) AS n FROM photos WHERE flickr_id IS NOT NULL"
    ).fetchone()["n"]
    pushed = db.conn.execute(
        """SELECT COUNT(*) AS n FROM photos
           WHERE privacy_state = 'approved_public'
             AND perms_pushed_flickr = 1"""
    ).fetchone()["n"]
    approved_pushable = db.conn.execute(
        """SELECT COUNT(*) AS n FROM photos
           WHERE privacy_state = 'approved_public'
             AND flickr_id IS NOT NULL
             AND perms_pushed_flickr = 0"""
    ).fetchone()["n"]
    db.close()

    if args.oneliner:
        short = {
            "candidate_public": "cand",
            "needs_review":     "review",
            "approved_public":  "approved",
            "already_public":   "public",
            "keep_private":     "private",
            "auto_private":     "auto",
            "skipped":          "skip",
            "duplicate_flickr": "dup",
        }
        parts = []
        for state, _ in order:
            n = by_state.get(state, 0)
            if n:
                parts.append(f"{short[state]}={n}")
        parts.append(f"total={total}")
        parts.append(f"flickr={flickr_linked}")
        parts.append(f"local={total - flickr_linked}")
        parts.append(f"pushed={pushed}")
        parts.append(f"pushable={approved_pushable}")
        print("  ".join(parts))
        return

    print()
    width = max(len(label) for _, label in order)
    for state, label in order:
        n = by_state.get(state, 0)
        if n:
            print(f"  {label:<{width}}  {n:>8,}")

    print(f"  {'─' * (width + 11)}")
    print(f"  {'Total':<{width}}  {total:>8,}")
    print()
    print(f"  Flickr-linked records:  {flickr_linked:>8,}")
    print(f"  Photos-only records:    {total - flickr_linked:>8,}")
    print(f"  Approved + pushed:      {pushed:>8,}")
    print(f"  Approved + pushable:    {approved_pushable:>8,}  (Flickr-linked, not yet pushed)")
    print()


def _run(fn, args, pairs):
    """Inject argv, call fn(), propagate non-zero exit codes."""
    _inject_argv(args, pairs)
    try:
        result = fn()
        if isinstance(result, int) and result != 0:
            sys.exit(result)
    except SystemExit:
        raise
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


