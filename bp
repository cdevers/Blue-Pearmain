def _pending_migrations(
    db_path: str,
    migrations_dir: Path,
) -> list[tuple[str, Path]]:
    """
    Return (migration_name, file_path) pairs for migrations not yet applied to
    db_path, sorted by filename (migrate_NNN_... sorts numerically by NNN).
    """
    import re
    import sqlite3

    _name_re = re.compile(r'^MIGRATION_NAME\s*=\s*["\']([^"\']+)["\']', re.MULTILINE)

    try:
        conn = sqlite3.connect(db_path)
        conn.row_factory = sqlite3.Row
        applied = {r["name"] for r in conn.execute("SELECT name FROM schema_migrations").fetchall()}
        conn.close()
    except sqlite3.OperationalError:
        # schema_migrations table doesn't exist yet (fresh DB) — treat all as pending
        applied = set()

    result: list[tuple[str, Path]] = []
    for mf in sorted(migrations_dir.glob("migrate_*.py")):
        m = _name_re.search(mf.read_text())
        if m and m.group(1) not in applied:
            result.append((m.group(1), mf))
    return result


def cmd_doctor(args):
    """
    Validate config, environment, and DB state before running the pipeline.
    Prints a pass/fail checklist and exits non-zero if any required check fails.
    """
    import sqlite3
    import yaml

    OK   = "✓"
    FAIL = "✗"
    WARN = "!"
    issues = []

    def check(symbol, label, detail=""):
        line = f"  {symbol}  {label}"
        if detail:
            line += f"\n       → {detail}"
        print(line)
        if symbol == FAIL:
            issues.append(label)

    print()
    print("Blue Pearmain — environment check")
    print("─" * 40)

    # ── 1. Config file ────────────────────────────────────────────────────────
    config_path = Path(args.config)
    if not config_path.exists():
        check(FAIL, f"Config file: {config_path}", "File not found — copy config/config.example.yml to config/config.yml and fill in your values")
        print()
        print("Cannot continue: config file is required for all other checks.")
        sys.exit(1)

    try:
        with open(config_path) as f:
            config = yaml.safe_load(f)
        check(OK, f"Config file: {config_path}")
    except Exception as e:
        check(FAIL, f"Config file: {config_path}", f"YAML parse error: {e}")
        sys.exit(1)

    # ── 2. Required config keys ───────────────────────────────────────────────
    def _cfg(*keys, label=None):
        val = config
        for k in keys:
            val = (val or {}).get(k)
        display = label or ".".join(keys)
        if not val:
            check(FAIL, f"Config key {display}", "Missing or empty — check config.yml")
        else:
            check(OK, f"Config key {display}")

    _cfg("database", "path")
    _cfg("photos_library", "path")
    _cfg("flickr", "api_key")
    _cfg("flickr", "api_secret")
    _cfg("flickr", "oauth_token")
    _cfg("flickr", "oauth_token_secret")
    _cfg("photos_library", "self_name", label="photos_library.self_name")

    if "photos_library" in config and not config["photos_library"].get("self_name"):
        check(WARN, "photos_library.self_name is empty — photos of named people will not be filtered as self")

    # ── 3. Photos library path ────────────────────────────────────────────────
    photos_path_raw = (config.get("photos_library") or {}).get("path", "")
    if photos_path_raw:
        photos_path = Path(photos_path_raw).expanduser()
        if photos_path.exists():
            check(OK, f"Photos library: {photos_path}")
        else:
            check(FAIL, f"Photos library: {photos_path}", "Path not found — check photos_library.path in config.yml")

    # ── 4. Database ───────────────────────────────────────────────────────────
    db_path_raw = (config.get("database") or {}).get("path", "")
    db_ok = False
    if db_path_raw:
        db_path = Path(db_path_raw).expanduser()
        if not db_path.exists():
            check(WARN, f"Database: {db_path}", "File not found — will be created on first run")
            db_ok = False
        else:
            try:
                conn = sqlite3.connect(str(db_path))
                conn.execute("SELECT 1")
                conn.close()
                check(OK, f"Database: {db_path}")
                db_ok = True
            except Exception as e:
                check(FAIL, f"Database: {db_path}", f"Cannot open: {e}")

    # ── 5. Migrations ─────────────────────────────────────────────────────────
    if db_ok:
        try:
            pending = _pending_migrations(str(db_path), ROOT / "db" / "migrations")
            if pending:
                for name, _ in pending:
                    check(WARN, f"Migration not applied: {name}")
                config_flag = f" --config {args.config}" if args.config != "config/config.yml" else ""
                print(f"       → Run: bp{config_flag} migrate")
            else:
                conn = sqlite3.connect(str(db_path))
                applied = [r[0] for r in conn.execute(
                    "SELECT name FROM schema_migrations ORDER BY name"
                ).fetchall()]
                conn.close()
                last = applied[-1] if applied else "(none)"
                check(OK, f"Migrations: all applied (latest: {last})")
        except Exception as e:
            check(WARN, "Migrations: could not check", str(e))

    # ── 6. photoscript importable ─────────────────────────────────────────────
    try:
        import photoscript  # noqa: F401
        check(OK, "photoscript: importable")
    except ImportError:
        check(FAIL, "photoscript: not found", "Run: uv add photoscript")

    # ── 7. Flickr credentials ping (opt-in) ───────────────────────────────────
    if args.check_flickr:
        try:
            from flickr.flickr_client import FlickrClient
            fc = config.get("flickr", {})
            client = FlickrClient(
                api_key=fc.get("api_key", ""),
                api_secret=fc.get("api_secret", ""),
                oauth_token=fc.get("oauth_token", ""),
                oauth_token_secret=fc.get("oauth_token_secret", ""),
            )
            result = client._call("flickr.test.login")
            username = result.get("user", {}).get("username", {}).get("_content", "?")
            check(OK, f"Flickr credentials: authenticated as {username}")
        except Exception as e:
            check(FAIL, "Flickr credentials: API call failed", str(e))

    # ── Summary ───────────────────────────────────────────────────────────────
    print()
    if issues:
        print(f"  {len(issues)} problem(s) found:")
        for i in issues:
            print(f"    {FAIL}  {i}")
        print()
        sys.exit(1)
    else:
        print("  All checks passed.")
        print()


def cmd_migrate(args: argparse.Namespace) -> None:
    """
    Auto-discover and apply all pending DB migrations in order.
    Safe to re-run — each migration is idempotent.
    """
    import importlib.util
    import yaml

    with open(args.config) as f:
        config = yaml.safe_load(f)

    db_path = str(Path(config["database"]["path"]).expanduser())
    migrations_dir = ROOT / "db" / "migrations"

    pending = _pending_migrations(db_path, migrations_dir)

    if not pending:
        print("All migrations already applied.")
        return

    dry_run = getattr(args, "dry_run", False)
    baseline = getattr(args, "baseline", False)

    if baseline:
        _baseline_migrations(db_path, pending, dry_run=dry_run)
        return

    for name, file_path in pending:
        if dry_run:
            print(f"  [dry-run] Would apply: {name}")
        else:
            print(f"  Applying: {name}…")
            spec = importlib.util.spec_from_file_location(name, file_path)
            module = importlib.util.module_from_spec(spec)  # type: ignore[arg-type]
            spec.loader.exec_module(module)  # type: ignore[union-attr]
            module.run(db_path, dry_run=False)

    count = len(pending)
    if dry_run:
        print(f"\n{count} migration(s) would be applied.")
    else:
        print(f"\n{count} migration(s) applied.")


def _baseline_migrations(
    db_path: str,
    pending: list[tuple[str, Path]],
    *,
    dry_run: bool,
) -> None:
    """Record pending migration names as applied WITHOUT running their DDL.

    Use once on a live DB whose schema already exists but whose
    schema_migrations table is out of sync — avoids re-running destructive
    table-rebuild migrations. Idempotent (INSERT OR IGNORE).
    """
    import sqlite3
    from datetime import datetime, timezone

    if dry_run:
        for name, _ in pending:
            print(f"  [dry-run] Would mark applied (baseline): {name}")
        print(f"\n{len(pending)} migration(s) would be marked applied (baseline).")
        return

    conn = sqlite3.connect(db_path)
    try:
        conn.execute(
            "CREATE TABLE IF NOT EXISTS schema_migrations "
            "(id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT UNIQUE NOT NULL, "
            "applied_at TEXT NOT NULL)"
        )
        now = datetime.now(timezone.utc).isoformat()
        for name, _ in pending:
            print(f"  Marking applied (baseline): {name}")
            conn.execute(
                "INSERT OR IGNORE INTO schema_migrations (name, applied_at) VALUES (?, ?)",
                (name, now),
            )
        conn.commit()
    finally:
        conn.close()

    print(f"\n{len(pending)} migration(s) marked applied (baseline; no DDL run).")


def _resolve_legacy_library_path(args: argparse.Namespace, config: dict) -> str:
    """--library wins; else fall back to optional config legacy_library.path."""
    if getattr(args, "library", None):
        return str(Path(args.library).expanduser())
    cfg = (config.get("legacy_library") or {}).get("path")
    if cfg:
        return str(Path(cfg).expanduser())
    print("Error: no library path. Pass --library <path> or set legacy_library.path in config.",
          file=sys.stderr)
    sys.exit(2)


