<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.cdevers.blue-pearmain.poller.plist
  launchd agent for Blue Pearmain Flickr poller

  Install:
    cp config/com.cdevers.blue-pearmain.poller.plist \
       ~/Library/LaunchAgents/com.cdevers.blue-pearmain.poller.plist
    launchctl bootstrap gui/$(id -u) \
       ~/Library/LaunchAgents/com.cdevers.blue-pearmain.poller.plist

  Run now (without waiting for interval):
    launchctl start com.cdevers.blue-pearmain.poller

  Uninstall:
    launchctl bootout gui/$(id -u) \
       ~/Library/LaunchAgents/com.cdevers.blue-pearmain.poller.plist
    rm ~/Library/LaunchAgents/com.cdevers.blue-pearmain.poller.plist

  If load/unload give "Input/output error", use bootout/bootstrap instead:
    launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/com.cdevers.blue-pearmain.poller.plist
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.cdevers.blue-pearmain.poller.plist

  Logs:
    tail -f /Users/cdevers/Library/Logs/BluePearmain/poller.log
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cdevers.blue-pearmain.poller</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Update these paths to match your actual install location -->
        <string>/Users/cdevers/.local/bin/uv</string>
        <string>run</string>
        <string>python</string>
        <string>/Users/cdevers/Code/Blue-Pearmain/poller/poller.py</string>
        <string>--config</string>
        <string>/Users/cdevers/Code/Blue-Pearmain/config/config.yml</string>
    </array>

    <!-- Run every 60 minutes -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <!-- Also run shortly after login, in case the Mac was asleep at the last interval -->
    <key>RunAtLoad</key>
    <false/>

    <!-- Stdout/stderr for debugging -->
    <key>StandardOutPath</key>
    <string>/Users/cdevers/Library/Logs/BluePearmain/poller.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/cdevers/Library/Logs/BluePearmain/poller.log</string>

    <!-- Working directory -->
    <key>WorkingDirectory</key>
    <string>/Users/cdevers/Code/Blue-Pearmain</string>

    <!-- Don't thrash if it keeps crashing -->
    <key>ThrottleInterval</key>
    <integer>300</integer>
</dict>
</plist>
